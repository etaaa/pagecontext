{
  "manifest_version": 3,
  "name": "PageContext",
  "description": "Copy page content and annotate sections to give LLMs context about any webpage.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "copy-article": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      },
      "description": "Copy article text"
    },
    "copy-page": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Copy full page"
    }
  }
}